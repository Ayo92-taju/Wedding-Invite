rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Couple / planner accounts that manage the site + guest list.
    // Confirmed by the couple (2026-07-10). Keep in sync with src/lib/adminConfig.js.
    // Compared lower-cased, so any capitalisation of the sign-in email matches.
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == 'momohvictor62@gmail.com' ||
          request.auth.token.email.lower() == 'ayolat16@gmail.com'
        )) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Ushers/gate staff — a signed-in Google account whitelisted for scanning.
    function isScanner() {
      return isSignedIn() && request.auth.token.email != null &&
        exists(/databases/$(database)/documents/authorized_scanners/$(request.auth.token.email.lower()));
    }

    // A guest update that only flips the three check-in fields, and only ever
    // ON (a used pass can never be reset by a scanner).
    function onlyCheckin() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['checkedIn', 'checkedInAt', 'checkedInBy'])
        && request.resource.data.checkedIn == true;
    }

    function isValidWish(data) {
      return data.keys().hasAll(['name', 'message', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.message is string && data.message.size() > 0 && data.message.size() <= 1000;
    }

    // ── Access-control system (parties · guests · tables · scanners) ──

    // A household/invitation. Guest-facing reads happen through a verified
    // session/Cloud Function (Phase C), so direct client reads are admin-only.
    match /parties/{partyId} {
      allow read, write: if isAdmin();
    }

    // Individual attendees. Doc id = inviteCode (the QR value).
    match /guests/{inviteCode} {
      allow get, list: if isAdmin();               // admin browses the whole list
      allow get: if isScanner();                   // usher reads one pass to check in
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isScanner() && onlyCheckin());
    }

    // Seating. Ushers read table names to display on a valid scan.
    match /tables/{tableId} {
      allow read: if isAdmin() || isScanner();
      allow write: if isAdmin();
    }

    // Gate whitelist. A signed-in user may read only their OWN scanner doc
    // (to learn they're authorized); the couple manages the list.
    match /authorized_scanners/{email} {
      allow get: if isSignedIn() && request.auth.token.email != null
        && request.auth.token.email.lower() == email;
      allow list, write: if isAdmin();
    }

    // ── Public marketing site ──────────────────────────────────

    // Well wishes / love notes — anyone may post; couple moderates.
    match /wellWishes/{wishId} {
      allow read: if true;
      allow create: if isValidWish(request.resource.data)
        && request.resource.data.createdAt == request.time;
      allow update, delete: if isAdmin();
    }

    // Public-read, admin-managed content.
    match /gifts/{giftId} {
      allow read: if true;
      allow update: if isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPurchased', 'purchasedBy']));
      allow create, delete: if isAdmin();
    }
    match /gallery/{photoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin infrastructure.
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
